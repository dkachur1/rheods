+/// Wrap gathered keyed bytes (`gather_keyed_bytes`) into a response body. Every
+/// recorded span is `encode_wire`'s JSON output, which always ends in a
+/// trailing `,` — for JSON streams strip the last one and wrap once (not
+/// per-span) into a single `[...]` array; binary streams pass the concatenated
+/// bytes through unchanged.
+fn wrap_keyed_body(st: &StreamState, buf: Bytes) -> Body {
+    if st.is_json {
+        let mut out = BytesMut::with_capacity(buf.len() + 2);
+        out.put_u8(b'[');
+        if !buf.is_empty() {
+            out.put_slice(&buf[..buf.len() - 1]);
+        }
+        out.put_u8(b']');
+        Body::Full(out.freeze())
+    } else {
+        Body::Full(buf)
+    }
+}
