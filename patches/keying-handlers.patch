+/// Gather every durable append recorded under `key` in `st.key_dir` whose
+/// (pre-append) offset falls in `[start, end)` and concatenate their raw wire
+/// bytes in append order. Each recorded span is the exact wire bytes of one
+/// durable append (see `handle_append_inner`), so a simple per-span offset
+/// filter is correct — no partial-span overlap is possible.
+///
+/// Serve like the reference servers do for filtered reads (see the ported
+/// technique notes): rather than one read syscall per scattered span, COALESCE
+/// spans separated by < KEYED_COALESCE_GAP into a single contiguous read, read
+/// that range ONCE (resident-cache first via `read_region_bytes` — the hot path
+/// the plain `read_range_bytes` misses), then copy out just the kept spans from
+/// the in-memory buffer. Turns N tiny reads into a few contiguous ones; the gap
+/// cap bounds the interleaved bytes read-and-discarded on a sparse large log.
+///
+/// Shared by keyed catch-up (`handle_keyed_catchup`) and keyed live reads
+/// (`long_poll_data`, `handle_sse`) — the one place span filtering + coalescing
+/// + resident-cache-first reads live, so the read paths can't drift apart.
+async fn gather_keyed_bytes(st: &Arc<StreamState>, key: &str, start: u64, end: u64) -> std::io::Result<Bytes> {
+    let spans: Vec<(u64, u64)> = st.keyed_spans(key, start, end);
+    let mut buf = BytesMut::new();
+    let mut i = 0;
+    while i < spans.len() {
+        let r_start = spans[i].0;
+        let mut r_end = spans[i].0 + spans[i].1;
+        let mut j = i + 1;
+        while j < spans.len() && spans[j].0.saturating_sub(r_end) <= KEYED_COALESCE_GAP {
+            r_end = spans[j].0 + spans[j].1;
+            j += 1;
+        }
+        // A short/failed read must not be silently forwarded as a (wrongly)
+        // shorter but well-formed body — propagate the error to the caller.
+        let region = read_region_bytes(st, r_start, r_end).await?;
+        for &(off, len) in &spans[i..j] {
+            let lo = (off - r_start) as usize;
+            buf.put_slice(&region[lo..lo + len as usize]);
+        }
+        i = j;
+    }
+    Ok(buf.freeze())
+}
