+    pub fn record_keyed_append(&self, key: &str, offset: u64, len: u64) {
+        let mut kd = self.key_dir.lock().unwrap_or_else(|e| e.into_inner());
+        kd.map.entry(key.to_string()).or_default().push((offset, len));
