+/// In-memory keyed-read index plus its durable journal (`key_journal.rs`), one
+/// lock (`StreamState::key_dir`) so the memory push and the durable append are
+/// a single atomic step: `handle_keyed_catchup`'s coalescing scan assumes push
+/// order == offset order, and replay after a restart must reproduce the exact
+/// order a live run saw.
+pub struct KeyDir {
+    map: HashMap<String, Vec<(u64, u64)>>,
+    journal: crate::key_journal::KeyJournal,
+}
+
+impl KeyDir {
+    /// A freshly created stream: no keyed appends yet, no journal file.
+    fn empty(file_path: &std::path::Path) -> Self {
+        KeyDir {
+            map: HashMap::new(),
+            journal: crate::key_journal::KeyJournal::empty(file_path),
         }
     }
+
+    /// Rebuild from the durable journal on boot — see
+    /// `key_journal::KeyJournal::recover`.
+    fn recovered(file_path: &std::path::Path) -> Self {
+        let (map, journal) = crate::key_journal::KeyJournal::recover(file_path);
+        KeyDir { map, journal }
+    }
 }
 
