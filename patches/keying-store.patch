+        // appender lock, so this adds no new write contention; a concurrent
+        // keyed READ on the same stream may briefly wait on the fsync. The
+        // deferred `write_meta_sync` flush remains as a backstop (a no-op once
+        // this has already cleared the dirty flag).
+        kd.journal.flush_if_dirty();
+    }
