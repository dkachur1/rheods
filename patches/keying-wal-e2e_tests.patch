+// ===========================================================================
+// (10) LIVE KEYED READS (`?key=` composed with `live=long-poll` / `live=sse`)
+// ===========================================================================
+
+/// A keyed long-poll wakes on ANY new append (not just its key's — same wait
+/// primitive as the unkeyed path), then filters to its key's bytes in the
+/// newly-arrived range and ALWAYS reports the underlying tail as
+/// `Stream-Next-Offset`. A wake whose new bytes were all another key's must
+/// still 200 (empty body, up-to-date) and advance past it — never re-scanned
+/// on the next long-poll — while a wake that does match the key returns
+/// exactly that key's bytes. Drives two sequential long-polls over the REAL
+/// HTTP path (`handle` → `handle_long_poll` → `long_poll_data`), interleaved
+/// with appends under two different `Stream-Key`s.
+#[tokio::test]
+async fn e2e_keyed_long_poll_advances_past_other_keys_data() {
+    let _guard = DurabilityGuard::wal();
+    let dir = tmp("keyed-long-poll");
+
+    let h = Harness::boot(&dir, Some(1), 1).unwrap();
+    create_stream(&h.store, "k/lp", OCTET).await;
+
+    // First long-poll: parked at offset 0 (the stream is empty, no backlog).
+    let store1 = Arc::clone(&h.store);
+    let poll1 = tokio::spawn(async move {
+        handlers::handle(
+            store1,
+            get_req("k/lp", Some(&format!("offset={}&live=long-poll&key=a", fork_offset(0)))),
+        )
+        .await
+    });
+    tokio::task::yield_now().await;
+
+    // Append under key "b" only — must wake the parked key=a long-poll with an
+    // up-to-date, EMPTY response that still advances past it.
+    let resp = handlers::handle(
+        Arc::clone(&h.store),
+        post_req_with("k/lp", OCTET, b"BBBB", &[("stream-key", "b")]),
+    )
+    .await;
+    assert!((200..300).contains(&resp.status), "append b expected 2xx, got {}", resp.status);
+
+    let resp1 = poll1.await.unwrap();
+    assert_eq!(resp1.status, 200, "keyed long-poll wake must 200, got {}", resp1.status);
+    let next1 = fork_offset(4);
+    assert_eq!(
+        resp_header(&resp1, "stream-next-offset"),
+        Some(next1.as_str()),
+        "next-offset must advance to the underlying tail even with no key match"
+    );
+    assert_eq!(resp_header(&resp1, "stream-up-to-date"), Some("true"));
+    assert_eq!(resp_header(&resp1, "cache-control"), Some("no-store"));
+    assert!(resp_header(&resp1, "etag").is_none(), "keyed live read must not carry an ETag");
+    match resp1.body {
+        crate::api::Body::Full(b) => assert!(b.is_empty(), "key=a must not see key b's bytes"),
+        _ => panic!("expected a Body::Full for a keyed long-poll read"),
+    }
+
+    // Second long-poll: from the advanced offset (4), parked again.
+    let store2 = Arc::clone(&h.store);
+    let poll2 = tokio::spawn(async move {
+        handlers::handle(
+            store2,
+            get_req("k/lp", Some(&format!("offset={}&live=long-poll&key=a", fork_offset(4)))),
+        )
+        .await
+    });
+    tokio::task::yield_now().await;
+
+    // Append under key "a" — must wake with exactly this key's bytes.
+    let resp = handlers::handle(
+        Arc::clone(&h.store),
+        post_req_with("k/lp", OCTET, b"AAAA", &[("stream-key", "a")]),
+    )
+    .await;
+    assert!((200..300).contains(&resp.status), "append a expected 2xx, got {}", resp.status);
+
+    let resp2 = poll2.await.unwrap();
+    assert_eq!(resp2.status, 200, "keyed long-poll wake must 200, got {}", resp2.status);
+    let next2 = fork_offset(8);
+    assert_eq!(resp_header(&resp2, "stream-next-offset"), Some(next2.as_str()));
+    match resp2.body {
+        crate::api::Body::Full(b) => assert_eq!(b, Bytes::from_static(b"AAAA")),
+        _ => panic!("expected a Body::Full for a keyed long-poll read"),
+    }
+
+    h.crash();
+    let _ = std::fs::remove_dir_all(&dir);
+}
