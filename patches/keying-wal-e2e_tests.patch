+/// A `Stream-Key` composes with every read mode, including live long-poll — a
+/// keyed long-poll over already-durable backlog (the `from < tail` fast path in
+/// `handle_long_poll`) must 200 with just that key's bytes, using the same
+/// filtered-projection headers as `handle_keyed_catchup` (no ETag, no-store).
+#[tokio::test]
+async fn e2e_keyed_long_poll_serves_backlog_filtered_by_key() {
+    let _guard = DurabilityGuard::wal();
+    let dir = tmp("keyed-live-backlog");
+
+    let h = Harness::boot(&dir, Some(1), 1).unwrap();
+    create_stream(&h.store, "k/s", OCTET).await;
+
+    for (key, body) in [("a", &b"AAAA"[..]), ("b", &b"BBBB"[..])] {
+        let resp = handlers::handle(
+            Arc::clone(&h.store),
+            post_req_with("k/s", OCTET, body, &[("stream-key", key)]),
+        )
+        .await;
+        assert!(
+            (200..300).contains(&resp.status),
+            "keyed append key={key} expected 2xx ack, got {}",
+            resp.status
+        );
+    }
+
+    let resp = handlers::handle(
+        Arc::clone(&h.store),
+        get_req("k/s", Some("offset=-1&live=long-poll&key=a")),
+    )
+    .await;
+    assert_eq!(resp.status, 200, "keyed long-poll backlog must 200, got {}", resp.status);
+    assert!(resp_header(&resp, "etag").is_none(), "keyed live read must not carry an ETag");
+    assert_eq!(resp_header(&resp, "cache-control"), Some("no-store"));
+    match resp.body {
+        crate::api::Body::Full(b) => assert_eq!(b, Bytes::from_static(b"AAAA")),
+        _ => panic!("expected a Body::Full for a keyed long-poll read"),
+    }
+
+    h.crash();
+    let _ = std::fs::remove_dir_all(&dir);
+}
