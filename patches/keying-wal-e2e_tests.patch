+// ===========================================================================
+// (9) KEYED CATCH-UP READS (`Stream-Key` append directory + `?key=` reads)
+// ===========================================================================
+
+/// Three durable WAL-mode appends interleaved across two routing keys must be
+/// gathered, in append order, per key — over the REAL handler path
+/// (`handle` → `handle_append_inner` records `st.key_dir`; `handle` →
+/// `handle_catchup` → `handle_keyed_catchup` reads it back), not a store-level
+/// unit test. This is the genuine end-to-end surface: an HTTP POST with a
+/// `Stream-Key` header, then an HTTP GET with `?key=`.
+#[tokio::test]
+async fn e2e_keyed_catchup_gathers_interleaved_appends_in_order() {
+    let _guard = DurabilityGuard::wal();
+    let dir = tmp("keyed-catchup");
+
+    let h = Harness::boot(&dir, Some(1), 1).unwrap();
+    create_stream(&h.store, "k/s", OCTET).await;
+
+    // Interleaved: a, b, a — key "a"'s two appends must concatenate in the
+    // order they were durably written, not the order they'd sort/group in.
+    for (key, body) in [("a", &b"AAAA"[..]), ("b", &b"BBBB"[..]), ("a", &b"AA"[..])] {
+        let resp = handlers::handle(
+            Arc::clone(&h.store),
+            post_req_with("k/s", OCTET, body, &[("stream-key", key)]),
+        )
+        .await;
+        assert!(
+            (200..300).contains(&resp.status),
+            "keyed append key={key} expected 2xx ack, got {}",
+            resp.status
+        );
+    }
+
+    let resp_a = handlers::handle(Arc::clone(&h.store), get_req("k/s", Some("key=a"))).await;
+    assert_eq!(resp_a.status, 200, "keyed catch-up for key=a must 200");
+    match resp_a.body {
+        crate::api::Body::Full(b) => assert_eq!(b, Bytes::from_static(b"AAAAAA")),
+        _ => panic!("expected a Body::Full for a keyed catch-up read"),
+    }
+
+    let resp_b = handlers::handle(Arc::clone(&h.store), get_req("k/s", Some("key=b"))).await;
+    assert_eq!(resp_b.status, 200, "keyed catch-up for key=b must 200");
+    match resp_b.body {
+        crate::api::Body::Full(b) => assert_eq!(b, Bytes::from_static(b"BBBB")),
+        _ => panic!("expected a Body::Full for a keyed catch-up read"),
+    }
+
+    h.crash();
+    let _ = std::fs::remove_dir_all(&dir);
+}
