+/// Build a `POST` (append) request for `path` with extra headers (e.g. `Stream-Key`).
+fn post_req_with(path: &str, content_type: &str, body: &[u8], extra: &[(&str, &str)]) -> Req {
+    let mut headers = vec![("content-type".to_string(), content_type.to_string())];
+    for (k, v) in extra {
+        headers.push((k.to_string(), v.to_string()));
+    }
+    Req {
+        method: Method::Post,
+        path: path.to_string(),
+        query: None,
+        headers,
+        body: Bytes::copy_from_slice(body),
+    }
+}
+
+/// Build a `GET` (read) request for `path` with an optional raw query string.
+fn get_req(path: &str, query: Option<&str>) -> Req {
+    Req {
+        method: Method::Get,
+        path: path.to_string(),
+        query: query.map(|s| s.to_string()),
+        headers: vec![],
+        body: Bytes::new(),
+    }
+}
+
+/// Look up a response header by (lowercase) name.
+fn resp_header<'a>(resp: &'a crate::api::Resp, name: &str) -> Option<&'a str> {
+    resp.headers.iter().find(|(k, _)| *k == name).map(|(_, v)| v.as_str())
+}
