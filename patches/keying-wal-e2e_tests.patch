+/// Durable-at-ack: a keyed append's index entry survives a crash even with NO
+/// prior close, NO meta flush, and NO debounce wait — proving the per-append
+/// journal fsync in `record_keyed_append` (not the close path) is what closes
+/// the crash-tail window. This is the difference between "as robust as Bun" and
+/// "robust within ~100ms": the append is acked, we crash immediately, and the
+/// key routing is still there on restart.
+#[tokio::test]
+async fn e2e_keyed_index_durable_at_ack_without_close() {
+    let _guard = DurabilityGuard::wal();
+    let dir = tmp("keyed-durable-at-ack");
+
+    let h = Harness::boot(&dir, Some(1), 1).unwrap();
+    create_stream(&h.store, "k/ack", OCTET).await;
+
+    for (key, body) in [("a", &b"AAAA"[..]), ("b", &b"BBBB"[..]), ("a", &b"AA"[..])] {
+        let resp = handlers::handle(
+            Arc::clone(&h.store),
+            post_req_with("k/ack", OCTET, body, &[("stream-key", key)]),
+        )
+        .await;
+        assert!(
+            (200..300).contains(&resp.status),
+            "keyed append key={key} expected 2xx ack, got {}",
+            resp.status
+        );
+    }
+
+    // No close, no meta flush — crash straight after the acks. Only the
+    // per-append fsync can have made the key routing durable.
+    h.crash();
+    let h2 = Harness::boot(&dir, None, 1).unwrap();
+
+    let resp_a = handlers::handle(Arc::clone(&h2.store), get_req("k/ack", Some("key=a"))).await;
+    assert_eq!(resp_a.status, 200, "key=a must survive a crash with no prior close");
+    match resp_a.body {
+        crate::api::Body::Full(b) => {
+            assert_eq!(b, Bytes::from_static(b"AAAAAA"), "key=a durable at ack")
+        }
+        _ => panic!("expected a Body::Full for a keyed catch-up read"),
+    }
+    let resp_b = handlers::handle(Arc::clone(&h2.store), get_req("k/ack", Some("key=b"))).await;
+    assert_eq!(resp_b.status, 200, "key=b must survive a crash with no prior close");
+    match resp_b.body {
+        crate::api::Body::Full(b) => {
+            assert_eq!(b, Bytes::from_static(b"BBBB"), "key=b durable at ack")
+        }
+        _ => panic!("expected a Body::Full for a keyed catch-up read"),
+    }
+
+    h2.crash();
+    let _ = std::fs::remove_dir_all(&dir);
+}
