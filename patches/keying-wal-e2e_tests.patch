+/// Restart durability for the keyed-read directory (`key_dir` / the
+/// `.keys` journal, see `key_journal.rs`): `key_dir` is in-memory state, so
+/// without a durable journal it would come back EMPTY after a crash even
+/// though the underlying data survives fine (it's in the WAL). This drives
+/// the same interleaved keyed appends as
+/// `e2e_keyed_catchup_gathers_interleaved_appends_in_order` above, then closes
+/// the stream (forcing the durable `write_meta_sync` that piggybacks the
+/// journal's fsync — see `store::write_meta_sync` — so the test doesn't race
+/// the ~100ms debounce), simulates a crash exactly like the no-loss tests
+/// (abort committers, drop the store + WalSet, keep the data dir), and
+/// reopens with the full startup recovery sequence. A `?key=` read after
+/// restart must return byte-identical to before it.
+#[tokio::test]
+async fn e2e_keyed_index_survives_restart() {
+    let _guard = DurabilityGuard::wal();
+    let dir = tmp("keyed-restart");
+
+    let h = Harness::boot(&dir, Some(1), 1).unwrap();
+    create_stream(&h.store, "k/restart", OCTET).await;
+
+    for (key, body) in [("a", &b"AAAA"[..]), ("b", &b"BBBB"[..]), ("a", &b"AA"[..])] {
+        let resp = handlers::handle(
+            Arc::clone(&h.store),
+            post_req_with("k/restart", OCTET, body, &[("stream-key", key)]),
+        )
+        .await;
+        assert!(
+            (200..300).contains(&resp.status),
+            "keyed append key={key} expected 2xx ack, got {}",
+            resp.status
+        );
+    }
+
+    // Force the durable meta write that piggybacks the journal fsync (see
+    // `write_meta_sync`), so the assertions below hold deterministically
+    // rather than racing the debounced ~100ms flush.
+    let close_resp = handlers::handle(
+        Arc::clone(&h.store),
+        post_req_with("k/restart", OCTET, b"", &[("stream-closed", "true")]),
+    )
+    .await;
+    assert!(
+        (200..300).contains(&close_resp.status),
+        "close expected 2xx, got {}",
+        close_resp.status
+    );
+
+    // Sanity before the crash (mirrors the non-restart keyed test above).
+    let resp_a = handlers::handle(Arc::clone(&h.store), get_req("k/restart", Some("key=a"))).await;
+    assert_eq!(resp_a.status, 200);
+    match resp_a.body {
+        crate::api::Body::Full(b) => assert_eq!(b, Bytes::from_static(b"AAAAAA")),
+        _ => panic!("expected a Body::Full for a keyed catch-up read"),
+    }
+    let resp_b = handlers::handle(Arc::clone(&h.store), get_req("k/restart", Some("key=b"))).await;
+    assert_eq!(resp_b.status, 200);
+    match resp_b.body {
+        crate::api::Body::Full(b) => assert_eq!(b, Bytes::from_static(b"BBBB")),
+        _ => panic!("expected a Body::Full for a keyed catch-up read"),
+    }
+
+    // CRASH + full recovery, exactly like the no-loss tests above.
+    h.crash();
+    let h2 = Harness::boot(&dir, None, 1).unwrap();
+
+    // The keyed index must be REBUILT from the `.keys` journal, not reset
+    // empty, so these reads still return exactly what they did pre-crash.
+    let resp_a2 = handlers::handle(Arc::clone(&h2.store), get_req("k/restart", Some("key=a"))).await;
+    assert_eq!(resp_a2.status, 200, "key=a catch-up must still 200 after restart");
+    match resp_a2.body {
+        crate::api::Body::Full(b) => {
+            assert_eq!(b, Bytes::from_static(b"AAAAAA"), "key=a spans survive restart")
+        }
+        _ => panic!("expected a Body::Full for a keyed catch-up read"),
+    }
+    let resp_b2 = handlers::handle(Arc::clone(&h2.store), get_req("k/restart", Some("key=b"))).await;
+    assert_eq!(resp_b2.status, 200, "key=b catch-up must still 200 after restart");
+    match resp_b2.body {
+        crate::api::Body::Full(b) => {
+            assert_eq!(b, Bytes::from_static(b"BBBB"), "key=b spans survive restart")
+        }
+        _ => panic!("expected a Body::Full for a keyed catch-up read"),
+    }
+
+    h2.crash();
+    let _ = std::fs::remove_dir_all(&dir);
+}
