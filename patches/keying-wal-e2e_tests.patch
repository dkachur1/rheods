+/// A keyed SSE subscriber emits only its key's bytes as `data` events; a wake
+/// whose new bytes were all another key's still advances `pos` (so the next
+/// control event's `streamNextOffset` moves past it) but sends NO `data` event
+/// — control only. Drives the REAL SSE handler (`handle` → `handle_sse`),
+/// draining the `Body::Channel` frame-by-frame between appends so each
+/// append's wake is observed individually rather than coalesced with the next.
+#[tokio::test]
+async fn e2e_keyed_sse_emits_only_key_frames() {
+    let _guard = DurabilityGuard::wal();
+    let dir = tmp("keyed-sse");
+
+    let h = Harness::boot(&dir, Some(1), 1).unwrap();
+    create_stream(&h.store, "k/sse", "text/plain").await;
+
+    let resp = handlers::handle(
+        Arc::clone(&h.store),
+        get_req("k/sse", Some("offset=-1&live=sse&key=a")),
+    )
+    .await;
+    assert_eq!(resp.status, 200, "sse handshake expected 200, got {}", resp.status);
+    let mut rx = match resp.body {
+        crate::api::Body::Channel(sb) => sb.rx,
+        _ => panic!("expected a Body::Channel for an SSE response"),
+    };
+
+    // Initial caught-up control event (no data yet — the stream is empty).
+    let initial = rx.recv().await.expect("initial control event");
+    let initial = String::from_utf8(initial.to_vec()).unwrap();
+    assert!(initial.contains("event: control"), "expected initial control event, got {initial:?}");
+    assert!(!initial.contains("event: data"), "no data expected before any append, got {initial:?}");
+
+    // Append under key "b" — the wake must be control-only (no data event),
+    // but still advances past it.
+    let resp = handlers::handle(
+        Arc::clone(&h.store),
+        post_req_with("k/sse", "text/plain", b"BBBB", &[("stream-key", "b")]),
+    )
+    .await;
+    assert!((200..300).contains(&resp.status), "append b expected 2xx, got {}", resp.status);
+    let after_b = rx.recv().await.expect("control event after key b append");
+    let after_b = String::from_utf8(after_b.to_vec()).unwrap();
+    assert!(!after_b.contains("event: data"), "key=a must not see key b's bytes, got {after_b:?}");
+    assert!(after_b.contains("event: control"), "must still advance via a control event, got {after_b:?}");
+
+    // Append under key "a" — must emit exactly this key's bytes as a data event.
+    let resp = handlers::handle(
+        Arc::clone(&h.store),
+        post_req_with("k/sse", "text/plain", b"AAAA", &[("stream-key", "a")]),
+    )
+    .await;
+    assert!((200..300).contains(&resp.status), "append a expected 2xx, got {}", resp.status);
+    let after_a = rx.recv().await.expect("data event after key a append");
+    let after_a = String::from_utf8(after_a.to_vec()).unwrap();
+    assert!(after_a.contains("event: data"), "expected a data event for key=a, got {after_a:?}");
+    assert!(after_a.contains("data:AAAA"), "expected key a's payload, got {after_a:?}");
+    assert!(!after_a.contains("BBBB"), "keyed SSE must not leak key b's bytes, got {after_a:?}");
+
+    h.crash();
+    let _ = std::fs::remove_dir_all(&dir);
+}
